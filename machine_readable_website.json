        "placements": [
          {
            "placementId": "ad-header-banner",
            "location": "header-bottom",
            "size": "728x90",
            "type": "display",
            "responsive": true,
            "lazyLoad": false,
            "targeting": {
              "keywords": [
                "technology",
                "ecommerce"
              ],
              "customParams": {
                "pageType": "homepage"
              }
            }
          },
          {
            "placementId": "ad-sidebar-1",
            "location": "sidebar-right-top",
            "size": "300x250",
            "type": "display",
            "responsive": true,
            "lazyLoad": true
          },
          {
            "placementId": "ad-in-content-1",
            "location": "content-mid",
            "size": "fluid",
            "type": "in-article",
            "insertAfter": "2nd-paragraph",
            "lazyLoad": true
          }
        ]
      },
      {
        "provider": "Amazon Associates",
        "enabled": true,
        "storeId": "example-20",
        "placements": [
          {
            "placementId": "amazon-native-1",
            "location": "sidebar-right-bottom",
            "type": "native-shopping",
            "category": "electronics"
          }
        ]
      },
      {
        "provider": "Custom Direct Ads",
        "enabled": true,
        "placements": [
          {
            "placementId": "direct-sponsored-post",
            "location": "content-top",
            "type": "sponsored-content",
            "advertiser": "Brand Name",
            "expiryDate": "2026-12-31"
          }
        ]
      }
    ],
    "adRefresh": {
      "enabled": true,
      "intervalSeconds": 30,
      "visibleOnly": true
    },
    "adBlockDetection": {
      "enabled": true,
      "message": "Please disable ad blocker to support our free content",
      "alternativeContent": true
    },
    "iabConsent": {
      "framework": "TCF v2.2",
      "cmpId": 123,
      "gdprApplies": true,
      "ccpaApplies": true
    },
    "structuredDataForAds": {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "hasPart": [
        {
          "@type": "SiteNavigationElement",
          "name": "Advertisement",
          "url": "https://example.com/advertising-policy"
        }
      ]
    }
  },
  "pageComponents": {
    "/home": {
      "pageId": "page-home",
      "layout": {
        "type": "default",
        "regions": [
          "header",
          "sidebar-left",
          "main",
          "sidebar-right",
          "footer"
        ],
        "gridTemplate": "header auto / 250px 1fr 300px"
      },
      "components": [
        {
          "componentId": "hero-banner",
          "componentType": "content",
          "position": "main-top",
          "contentType": "banner",
          "data": {
            "headline": "Welcome to Example",
            "subheadline": "The best solution for your needs",
            "backgroundImage": "https://example.com/hero-bg.jpg",
            "ctaButton": {
              "label": "Explore",
              "link": "/products"
            }
          },
          "structuredData": {
            "@type": "WPHeader",
            "headline": "Welcome to Example"
          }
        },
        {
          "componentId": "featured-products",
          "componentType": "dynamic",
          "position": "main-middle",
          "contentType": "product-grid",
          "dataSource": {
            "type": "api",
            "endpoint": "/api/products/featured",
            "cacheTTL": 3600
          }
        },
        {
          "componentId": "newsletter-signup",
          "componentType": "form",
          "position": "sidebar-right-middle",
          "contentType": "form",
          "formId": "newsletter-form",
          "formRef": "forms.newsletterSignup"
        }
      ]
    },
    "/products/:id": {
      "pageId": "page-product-detail",
      "layout": {
        "type": "product",
        "regions": [
          "header",
          "main",
          "sidebar-right",
          "footer"
        ]
      },
      "components": [
        {
          "componentId": "product-gallery",
          "componentType": "dynamic",
          "position": "main-left",
          "contentType": "image-gallery",
          "dataSource": {
            "type": "routeParam",
            "param": "id",
            "endpoint": "/api/products/{id}/images"
          }
        },
        {
          "componentId": "product-info",
          "componentType": "dynamic",
          "position": "main-right",
          "contentType": "product",
          "dataSource": {
            "type": "routeParam",
            "param": "id",
            "endpoint": "/api/products/{id}"
          },
          "structuredData": {
            "@type": "Product",
            "name": "{{product.name}}"
          }
        },
        {
          "componentId": "add-to-cart-form",
          "componentType": "form",
          "position": "main-right-bottom",
          "contentType": "form",
          "formId": "add-to-cart",
          "fields": [
            {
              "name": "productId",
              "type": "hidden",
              "value": "{{route.params.id}}"
            },
            {
              "name": "quantity",
              "type": "number",
              "required": true,
              "defaultValue": 1,
              "min": 1,
              "max": 99
            }
          ],
          "submitButton": {
            "label": "Add to Cart",
            "action": "/api/cart/add"
          }
        },
        {
          "componentId": "reviews-section",
          "componentType": "dynamic",
          "position": "main-bottom",
          "contentType": "user-reviews",
          "dataSource": {
            "type": "api",
            "endpoint": "/api/products/{id}/reviews"
          }
        },
        {
          "componentId": "write-review-form",
          "componentType": "form",
          "position": "main-bottom-after-reviews",
          "contentType": "form",
          "formId": "write-review",
          "requiresAuth": true,
          "fields": [
            {
              "name": "rating",
              "type": "select",
              "required": true,
              "options": [
                1,
                2,
                3,
                4,
                5
              ]
            },
            {
              "name": "title",
              "type": "text",
              "required": true,
              "maxLength": 100
            },
            {
              "name": "comment",
              "type": "textarea",
              "required": true,
              "maxLength": 2000
            }
          ]
        }
      ]
    },
    "/contact": {
      "pageId": "page-contact",
      "components": [
        {
          "componentId": "contact-form",
          "componentType": "form",
          "position": "main-center",
          "contentType": "form",
          "formRef": "forms.contact",
          "structuredData": {
            "@type": "ContactPage"
          }
        },
        {
          "componentId": "map-embed",
          "componentType": "embed",
          "position": "sidebar-right",
          "contentType": "map",
          "data": {
            "src": "https://maps.google.com/..."
          }
        }
      ]
    },
    "/dashboard": {
      "pageId": "page-dashboard",
      "visibility": "deep-web",
      "requiresAuth": true,
      "components": [
        {
          "componentId": "user-stats",
          "componentType": "dynamic",
          "dataSource": {
            "type": "authenticated-api",
            "endpoint": "/api/user/stats"
          }
        },
        {
          "componentId": "recent-orders",
          "componentType": "dynamic",
          "dataSource": {
            "type": "authenticated-api",
            "endpoint": "/api/user/orders?limit=5"
          }
        },
        {
          "componentId": "profile-completeness",
          "componentType": "form",
          "formId": "profile-completeness",
          "fields": [
            {
              "name": "phone",
              "type": "tel",
              "required": false
            },
            {
              "name": "address",
              "type": "text",
              "required": false
            }
          ]
        }
      ]
    },
    "/admin/content/new": {
      "pageId": "page-admin-content-create",
      "visibility": "deep-web",
      "requiresAuth": true,
      "rolesAllowed": [
        "admin",
        "editor"
      ],
      "components": [
        {
          "componentId": "content-editor",
          "componentType": "form",
          "formId": "create-content",
          "contentTypeSelector": true,
          "fields": [
            {
              "name": "contentType",
              "type": "select",
              "options": [
                "blog-post",
                "product",
                "event",
                "job-posting"
              ]
            },
            {
              "name": "title",
              "type": "text",
              "required": true
            },
            {
              "name": "slug",
              "type": "text",
              "required": true,
              "pattern": "^[a-z0-9-]+$"
            },
            {
              "name": "body",
              "type": "rich-text-editor",
              "required": true
            },
            {
              "name": "seoMetaTitle",
              "type": "text",
              "maxLength": 60
            },
            {
              "name": "seoMetaDescription",
              "type": "textarea",
              "maxLength": 160
            },
            {
              "name": "publishNow",
              "type": "checkbox",
              "defaultValue": true
            },
            {
              "name": "scheduleDate",
              "type": "datetime-local",
              "conditionalVisibility": {
                "dependsOn": "publishNow",
                "operator": "equals",
                "value": false
              }
            }
          ],
          "submitButton": {
            "label": "Publish",
            "action": "/api/admin/content"
          }
        }
      ]
    }
  },
  "forms": {
    "newsletterSignup": {
      "formId": "newsletter-signup",
      "method": "POST",
      "action": "/api/newsletter/subscribe",
      "fields": [
        {
          "name": "email",
          "type": "email",
          "required": true,
          "validationRules": [
            {
              "rule": "email",
              "message": "Valid email required"
            }
          ]
        },
        {
          "name": "consent",
          "type": "checkbox",
          "required": true,
          "label": "I agree to receive marketing emails"
        }
      ]
    },
    "login": {
      "formId": "login-form",
      "method": "POST",
      "action": "/api/auth/login",
      "csrfProtected": true,
      "fields": [
        {
          "name": "email",
          "type": "email",
          "required": true
        },
        {
          "name": "password",
          "type": "password",
          "required": true,
          "minLength": 8
        },
        {
          "name": "rememberMe",
          "type": "checkbox",
          "defaultValue": false
        }
      ],
      "successAction": {
        "type": "redirect",
        "redirectUrl": "/dashboard"
      }
    },
    "register": {
      "formId": "register-form",
      "method": "POST",
      "action": "/api/auth/register",
      "fields": [
        {
          "name": "fullName",
          "type": "text",
          "required": true
        },
        {
          "name": "email",
          "type": "email",
          "required": true
        },
        {
          "name": "password",
          "type": "password",
          "required": true,
          "minLength": 8
        },
        {
          "name": "confirmPassword",
          "type": "password",
          "required": true,
          "validationRules": [
            {
              "rule": "match:password",
              "message": "Passwords must match"
            }
          ]
        },
        {
          "name": "termsAccepted",
          "type": "checkbox",
          "required": true
        }
      ]
    },
    "checkout": {
      "formId": "checkout-form",
      "method": "POST",
      "action": "/api/checkout",
      "encType": "application/json",
      "fields": [
        {
          "name": "shippingAddress",
          "type": "address-group",
          "required": true
        },
        {
          "name": "billingAddress",
          "type": "address-group",
          "required": true
        },
        {
          "name": "paymentMethod",
          "type": "select",
          "options": [
            "credit_card",
            "paypal",
            "apple_pay"
          ],
          "required": true
        },
        {
          "name": "cardDetails",
          "type": "payment-card",
          "conditionalVisibility": {
            "dependsOn": "paymentMethod",
            "operator": "equals",
            "value": "credit_card"
          }
        },
        {
          "name": "promoCode",
          "type": "text",
          "required": false
        }
      ]
    }
  },
  "deepWeb": {
    "description": "Areas not accessible to search engines (authenticated, paywalled, or restricted)",
    "protectedRoutes": [
      "/dashboard",
      "/account/*",
      "/orders/*",
      "/admin/*",
      "/checkout",
      "/profile",
      "/settings"
    ],
    "authMethods": [
      "oauth2",
      "jwt",
      "session-cookie",
      "mfa"
    ],
    "paywalledContent": {
      "/premium/*": {
        "type": "subscription",
        "plans": [
          "basic",
          "pro",
          "enterprise"
        ],
        "sampleAllowed": true,
        "sampleLength": "first 200 words"
      },
      "/courses/*/lesson/*": {
        "type": "one-time-purchase",
        "price": 49.99
      }
    },
    "robotsTxtRules": {
      "disallow": [
        "/dashboard",
        "/admin",
        "/api/*",
        "/checkout",
        "/account/*"
      ],
      "allow": [
        "/premium/sample"
      ],
      "crawlDelay": 1
    },
    "authenticationApi": {
      "login": "/api/auth/login",
      "logout": "/api/auth/logout",
      "refresh": "/api/auth/refresh",
      "sessionValidation": "/api/auth/validate"
    },
    "seoForDeepWeb": {
      "generateAuthGatedSitemap": false,
      "useNoIndexHeaders": true,
      "structuredDataForPaywall": {
        "@type": "WebPage",
        "isAccessibleForFree": false,
        "hasPart": {
          "@type": "CreativeWork",
          "isAccessibleForFree": false,
          "cssSelector": ".premium-content"
        }
      }
    }
  },
  "searchEngineOptimization": {
    "sitemapXml": "https://example.com/sitemap.xml",
    "sitemapIndex": "https://example.com/sitemap_index.xml",
    "robotsTxt": "https://example.com/robots.txt",
    "jsonLdContext": "https://schema.org",
    "hydrationStrategy": "server-side-rendering",
    "prerenderRoutes": [
      "/home",
      "/about",
      "/contact",
      "/products",
      "/blog"
    ],
    "dynamicRoutesPatterns": [
      "/products/*",
      "/blog/*",
      "/jobs/*"
    ],
    "structuredDataGloballyInjected": [
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Example Website",
        "url": "https://example.com",
        "logo": "https://example.com/logo.png",
        "sameAs": [
          "https://facebook.com/example",
          "https://x.com/example"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "support@example.com",
          "contactType": "customer service"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "url": "https://example.com",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://example.com/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    ],
    "breadcrumbs": {
      "enabled": true,
      "position": "top-of-main",
      "structuredData": true
    },
    "pagination": {
      "prevNextLinks": true,
      "relPrevNext": true
    },
    "canonicalUrls": {
      "enforceWww": true,
      "trailingSlash": "without",
      "removeUtmParams": true
    },
    "hreflangTags": {
      "enabled": true,
      "generateAutomatically": true
    },
    "imageSeo": {
      "autoAltText": true,
      "lazyLoading": true,
      "webpFormat": true,
      "srcsetResponsive": true
    },
    "performanceSeo": {
      "coreWebVitals": {
        "lcpTarget": "< 2.5s",
        "fidTarget": "< 100ms",
        "clsTarget": "< 0.1"
      },
      "structuredDataInline": true,
      "criticalCssInline": true
    }
  },
  "stateManagement": {
    "framework": "react | vue | angular | svelte",
    "store": {
      "user": "global (persisted)",
      "cart": "global (persisted)",
      "ui": "local (non-persisted)",
      "routeParams": "dynamic",
      "forms": "local + validation state",
      "ads": "global + consent"
    },
    "dataFetchingStrategy": "client-side-with-cache",
    "cacheStrategy": "stale-while-revalidate",
    "persistence": {
      "localStorage": [
        "userPreferences",
        "cart"
      ],
      "sessionStorage": [
        "formDrafts"
      ],
      "cookies": [
        "authToken",
        "consent"
      ]
    },
    "offlineSupport": {
      "enabled": false,
      "serviceWorker": "/sw.js",
      "cacheFirst": [
        "/offline.html",
        "/static/css",
        "/static/js"
      ]
    }
  },
  "apiEndpoints": {
    "rest": {
      "baseUrl": "https://api.example.com/v1",
      "endpoints": {
        "products": "/products",
        "productDetail": "/products/{id}",
        "categories": "/categories",
        "search": "/search",
        "user": "/user",
        "cart": "/cart",
        "checkout": "/checkout",
        "auth": {
          "login": "/auth/login",
          "register": "/auth/register",
          "logout": "/auth/logout",
          "refresh": "/auth/refresh"
        },
        "content": {
          "blog": "/content/blog",
          "pages": "/content/pages",
          "faqs": "/content/faqs"
        },
        "analytics": "/analytics/events"
      }
    },
    "graphql": {
      "endpoint": "https://api.example.com/graphql",
      "introspection": false,
      "queries": {
        "product": "query Product($id: ID!) { product(id: $id) { id name price ... } }"
      }
    }
  },
  "analytics": {
    "providers": [
      {
        "name": "Google Analytics 4",
        "measurementId": "G-XXXXXXXX",
        "enabled": true,
        "consentRequired": true,
        "customEvents": [
          "page_view",
          "view_item",
          "add_to_cart",
          "begin_checkout",
          "purchase"
        ]
      },
      {
        "name": "Google Tag Manager",
        "containerId": "GTM-XXXXXX",
        "enabled": true
      }
    ],
    "privacy": {
      "anonymizeIp": true,
      "respectDoNotTrack": true,
      "cookieLessTracking": false
    }
  },
  "security": {
    "csp": {
      "enabled": true,
      "directives": {
        "default-src": [
          "'self'"
        ],
        "script-src": [
          "'self'",
          "'unsafe-inline'",
          "https://www.googletagmanager.com"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "img-src": [
          "'self'",
          "data:",
          "https:"
        ],
        "connect-src": [
          "'self'",
          "https://api.example.com"
        ]
      }
    },
    "cors": {
      "allowedOrigins": [
        "https://example.com"
      ],
      "allowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE"
      ],
      "allowCredentials": true
    },
    "headers": {
      "xFrameOptions": "DENY",
      "xContentTypeOptions": "nosniff",
      "referrerPolicy": "strict-origin-when-cross-origin",
      "permissionsPolicy": "geolocation=(), microphone=(), camera=()"
    },
    "inputValidation": {
      "sanitizeHtml": true,
      "escapeJson": true,
      "rateLimiting": {
        "enabled": true,
        "maxRequestsPerMinute": 60,
        "maxRequestsPerIpPerMinute": 120
      }
    }
  },
  "progressiveWebApp": {
    "enabled": true,
    "manifest": {
      "name": "Example Website",
      "short_name": "Example",
      "start_url": "/home",
      "display": "standalone",
      "theme_color": "#ffffff",
      "background_color": "#000000",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        },
        {
          "src": "/icons/icon-512.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    },
    "offlinePage": "/offline.html",
    "pushNotifications": {
      "enabled": true,
      "vapidPublicKey": "BC...",
      "subscribeEndpoint": "/api/notifications/subscribe"
    }
  },
  "internationalization": {
    "enabled": true,
    "defaultLocale": "en-US",
    "supportedLocales": [
      "en-US",
      "es-ES",
      "fr-FR",
      "de-DE",
      "ja-JP"
    ],
    "strategy": "url-path",
    "urlPattern": "/{locale}/path",
    "translationFiles": "/locales/{locale}/common.json",
    "rtlLanguages": [
      "ar-SA",
      "he-IL"
    ],
    "dateFormat": "locale-specific",
    "currencyFormat": "locale-specific"
  },
  "accessibility": {
    "wcagLevel": "AA",
    "ariaLabels": true,
    "keyboardNavigation": true,
    "skipToMainContent": true,
    "highContrastSupport": false,
    "screenReaderOptimized": true,
    "focusManagement": true,
    "announceLiveRegions": true
  },
  "errorHandling": {
    "404Page": "/not-found",
    "500Page": "/error",
    "offlinePage": "/offline",
    "errorTracking": {
      "sentryDsn": "https://xxx@sentry.io/xxx",
      "environment": "production"
    },
    "gracefulDegradation": {
      "javascriptDisabled": "show-noscript-message",
      "apiUnavailable": "show-cached-data"
    }
  }
}
