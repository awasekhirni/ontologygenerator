{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "meta": {
    "templateVersion": "2.0.0",
    "name": "Universal SPA Semantic Blueprint",
    "description": "Complete website structure for content, forms, deep web, ads, and SEO",
    "compatibleWith": [
      "Google",
      "Bing",
      "DuckDuckGo",
      "Yandex",
      "Baidu",
      "Brave",
      "Qwant"
    ],
    "supportedStandards": [
      "Schema.org",
      "JSON-LD",
      "OpenGraph",
      "Twitter Cards",
      "Dublin Core"
    ],
    "lastUpdated": "2026-04-13T00:00:00Z"
  },
  "siteMap": {
    "domain": "https://example.com",
    "siteName": "Example Website",
    "siteDescription": "Comprehensive platform for...",
    "siteLanguage": "en-US",
    "alternateLanguages": [
      "es-ES",
      "fr-FR",
      "de-DE"
    ],
    "defaultRoute": "/home",
    "routes": [
      {
        "path": "/home",
        "title": "Home",
        "contentType": "homepage",
        "visibility": "public",
        "priority": 1,
        "changefreq": "daily",
        "lastModified": "2026-04-13T00:00:00Z",
        "requiresAuth": false,
        "rolesAllowed": [
          "*"
        ],
        "seo": {
          "metaTitle": "Home | Example Website",
          "metaDescription": "Welcome to the best platform for...",
          "metaKeywords": [
            "keyword1",
            "keyword2"
          ],
          "ogImage": "https://example.com/og-home.jpg",
          "canonicalUrl": "https://example.com/home",
          "noIndex": false,
          "noFollow": false
        }
      },
      {
        "path": "/dashboard",
        "title": "User Dashboard",
        "contentType": "dashboard",
        "visibility": "deep-web",
        "priority": 0.5,
        "changefreq": "always",
        "requiresAuth": true,
        "rolesAllowed": [
          "user",
          "admin"
        ],
        "seo": {
          "metaTitle": "My Dashboard | Example",
          "metaDescription": "Your personal dashboard",
          "noIndex": true,
          "noFollow": true,
          "disallowCrawl": true
        },
        "deepWeb": {
          "type": "authenticated-area",
          "authProvider": "jwt-oauth2",
          "sessionRequired": true,
          "csrfProtected": true,
          "dataIsolation": "user-specific",
          "cacheControl": "private, no-store"
        }
      },
      {
        "path": "/admin/panel",
        "title": "Admin Panel",
        "contentType": "admin-dashboard",
        "visibility": "deep-web",
        "priority": 0.1,
        "requiresAuth": true,
        "rolesAllowed": [
          "admin",
          "superadmin"
        ],
        "deepWeb": {
          "type": "restricted-admin",
          "auditLogging": true,
          "ipWhitelist": [
            "192.168.1.0/24"
          ],
          "mfaRequired": true
        }
      }
    ]
  },
  "globalComponents": {
    "header": {
      "componentId": "global-header",
      "componentType": "common",
      "priority": "critical",
      "ssrRequired": true,
      "content": {
        "logo": {
          "src": "https://example.com/logo.svg",
          "alt": "Example Website Logo",
          "link": "/home",
          "width": 150,
          "height": 40
        },
        "navigation": {
          "type": "main-menu",
          "items": [
            {
              "label": "Home",
              "link": "/home",
              "activeOnExact": true,
              "requiresAuth": false
            },
            {
              "label": "Products",
              "link": "/products",
              "activeOnPattern": "/products",
              "requiresAuth": false
            },
            {
              "label": "Blog",
              "link": "/blog",
              "activeOnPattern": "/blog",
              "requiresAuth": false
            },
            {
              "label": "Dashboard",
              "link": "/dashboard",
              "requiresAuth": true,
              "rolesAllowed": [
                "user",
                "admin"
              ]
            }
          ]
        },
        "searchBar": {
          "enabled": true,
          "type": "instant-search",
          "endpoint": "/api/search",
          "placeholder": "Search products, articles...",
          "debounceMs": 300
        },
        "userMenu": {
          "authenticatedContent": {
            "avatar": "/api/user/avatar",
            "menuItems": [
              {
                "label": "My Profile",
                "link": "/profile"
              },
              {
                "label": "Account Settings",
                "link": "/settings"
              },
              {
                "label": "Logout",
                "action": "logout"
              }
            ]
          },
          "guestContent": {
            "items": [
              {
                "label": "Login",
                "link": "/login"
              },
              {
                "label": "Register",
                "link": "/register"
              }
            ]
          }
        }
      }
    },
    "footer": {
      "componentId": "global-footer",
      "componentType": "common",
      "content": {
        "copyright": "© 2026 Example Website. All rights reserved.",
        "columns": [
          {
            "title": "Company",
            "links": [
              {
                "label": "About",
                "link": "/about"
              },
              {
                "label": "Careers",
                "link": "/careers"
              },
              {
                "label": "Press",
                "link": "/press"
              }
            ]
          },
          {
            "title": "Support",
            "links": [
              {
                "label": "Help Center",
                "link": "/help"
              },
              {
                "label": "Contact",
                "link": "/contact"
              },
              {
                "label": "FAQs",
                "link": "/faqs"
              }
            ]
          }
        ],
        "socialLinks": [
          {
            "platform": "facebook",
            "url": "https://facebook.com/example",
            "ariaLabel": "Facebook"
          },
          {
            "platform": "x",
            "url": "https://x.com/example",
            "ariaLabel": "X (Twitter)"
          },
          {
            "platform": "linkedin",
            "url": "https://linkedin.com/company/example",
            "ariaLabel": "LinkedIn"
          }
        ],
        "newsletterSignup": {
          "enabled": true,
          "endpoint": "/api/newsletter/subscribe",
          "method": "POST"
        }
      }
    },
    "sidePanels": {
      "leftPanel": {
        "componentId": "global-left-panel",
        "enabled": true,
        "defaultState": "collapsed",
        "position": "left",
        "width": "280px",
        "content": {
          "categoryNavigation": {
            "enabled": true,
            "dataSource": "/api/categories"
          },
          "filters": {
            "enabled": true,
            "type": "dynamic-facets"
          }
        }
      },
      "rightPanel": {
        "componentId": "global-right-panel",
        "enabled": true,
        "defaultState": "collapsed",
        "position": "right",
        "width": "320px",
        "content": {
          "cart": {
            "enabled": true,
            "emptyMessage": "Your cart is empty"
          },
          "recentlyViewed": {
            "enabled": true,
            "maxItems": 5,
            "storageType": "localStorage"
          },
          "chatSupport": {
            "enabled": true,
            "status": "online",
            "responseTime": "< 2 min"
          }
        }
      }
    },
    "modals": {
      "loginModal": {
        "componentId": "modal-login",
        "trigger": "click",
        "content": "form",
        "formId": "login-form"
      },
      "cookieConsent": {
        "enabled": true,
        "position": "bottom",
        "theme": "gdpr-compliant"
      }
    }
  },
  "contentTypes": {
    "blog-post": {
      "displayName": "Blog Article",
      "schema": {
        "id": "string (uuid)",
        "title": "string",
        "slug": "string",
        "excerpt": "string (max 160 chars)",
        "body": "string (HTML/Markdown)",
        "featuredImage": "string (url)",
        "author": {
          "name": "string",
          "avatar": "string (url)",
          "bio": "string"
        },
        "publishDate": "datetime (ISO8601)",
        "modifiedDate": "datetime",
        "category": "string",
        "tags": [
          "string"
        ],
        "readingTime": "number (minutes)",
        "likes": "number",
        "comments": "number"
      },
      "structuredData": {
        "@type": "BlogPosting",
        "headline": "{{title}}",
        "datePublished": "{{publishDate}}",
        "author": {
          "@type": "Person",
          "name": "{{author.name}}"
        }
      },
      "example": {
        "id": "post-456",
        "title": "10 Tips for Better SEO",
        "slug": "10-tips-better-seo",
        "excerpt": "Learn how to improve your search rankings with these actionable tips.",
        "body": "<p>Full article content here...</p>",
        "featuredImage": "https://example.com/images/seo-tips.jpg",
        "author": {
          "name": "Jane Doe",
          "avatar": "https://example.com/avatars/jane.jpg",
          "bio": "SEO Specialist"
        },
        "publishDate": "2026-04-10T09:00:00Z",
        "modifiedDate": "2026-04-12T14:30:00Z",
        "category": "SEO",
        "tags": [
          "SEO",
          "marketing",
          "tips"
        ],
        "readingTime": 5,
        "likes": 342,
        "comments": 28
      }
    },
    "product": {
      "displayName": "E-commerce Product",
      "schema": {
        "id": "string (sku)",
        "name": "string",
        "description": "string",
        "shortDescription": "string (max 200 chars)",
        "price": "number (decimal)",
        "compareAtPrice": "number (nullable)",
        "currency": "string (ISO 4217)",
        "inStock": "boolean",
        "stockQuantity": "number",
        "images": [
          "string (urls)"
        ],
        "videos": [
          "string (urls)"
        ],
        "categories": [
          "string"
        ],
        "tags": [
          "string"
        ],
        "attributes": {
          "brand": "string",
          "color": [
            "string"
          ],
          "size": [
            "string"
          ],
          "material": "string",
          "weight": "string"
        },
        "reviews": {
          "averageRating": "number (0-5)",
          "totalReviews": "number",
          "ratingDistribution": {
            "1": "number",
            "2": "number",
            "3": "number",
            "4": "number",
            "5": "number"
          }
        },
        "variants": [
          {
            "sku": "string",
            "attributes": {},
            "price": "number",
            "inStock": "boolean"
          }
        ],
        "relatedProducts": [
          "string (skus)"
        ],
        "upsellProducts": [
          "string (skus)"
        ]
      },
      "structuredData": {
        "@type": "Product",
        "name": "{{name}}",
        "description": "{{description}}",
        "sku": "{{id}}",
        "offers": {
          "@type": "Offer",
          "price": "{{price}}",
          "priceCurrency": "{{currency}}",
          "availability": "https://schema.org/{{#if inStock}}InStock{{else}}OutOfStock{{/if}}"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{reviews.averageRating}}",
          "reviewCount": "{{reviews.totalReviews}}"
        }
      },
      "example": {
