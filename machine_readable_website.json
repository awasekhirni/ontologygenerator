    "form": {
      "displayName": "Web Form",
      "schema": {
        "formId": "string",
        "formName": "string",
        "method": "GET | POST | PUT | DELETE",
        "action": "string (endpoint)",
        "encType": "application/x-www-form-urlencoded | multipart/form-data | application/json",
        "csrfProtected": "boolean",
        "validation": "client | server | both",
        "fields": [
          {
            "name": "string",
            "label": "string",
            "type": "text | email | password | number | tel | date | textarea | select | checkbox | radio | file | hidden | recaptcha",
            "required": "boolean",
            "placeholder": "string (optional)",
            "defaultValue": "string | number | boolean (optional)",
            "minLength": "number (optional)",
            "maxLength": "number (optional)",
            "pattern": "string (regex) (optional)",
            "options": [
              {
                "value": "string",
                "label": "string"
              }
            ],
            "validationRules": [
              {
                "rule": "required | email | min | max | pattern | custom",
                "message": "string"
              }
            ],
            "conditionalVisibility": {
              "dependsOn": "string (fieldName)",
              "operator": "equals | notEquals | contains",
              "value": "any"
            }
          }
        ],
        "submitButton": {
          "label": "string",
          "loadingLabel": "string (optional)",
          "disabledUntilValid": "boolean"
        },
        "successAction": {
          "type": "redirect | modal | message",
          "redirectUrl": "string (if type=redirect)",
          "successMessage": "string (if type=modal|message)"
        },
        "rateLimiting": {
          "enabled": "boolean",
          "maxSubmissionsPerIp": "number",
          "timeWindowSeconds": "number"
        }
      },
      "example": {
        "formId": "contact-form",
        "formName": "Contact Us",
        "method": "POST",
        "action": "/api/contact/submit",
        "encType": "application/json",
        "csrfProtected": true,
        "validation": "both",
        "fields": [
          {
            "name": "fullName",
            "label": "Full Name",
            "type": "text",
            "required": true,
            "placeholder": "John Doe",
            "minLength": 2,
            "maxLength": 100,
            "validationRules": [
              {
                "rule": "required",
                "message": "Name is required"
              },
              {
                "rule": "min:2",
                "message": "Name must be at least 2 characters"
              }
            ]
          },
          {
            "name": "email",
            "label": "Email Address",
            "type": "email",
            "required": true,
            "placeholder": "john@example.com",
            "validationRules": [
              {
                "rule": "required",
                "message": "Email is required"
              },
              {
                "rule": "email",
                "message": "Please enter a valid email"
              }
            ]
          },
          {
            "name": "inquiryType",
            "label": "Inquiry Type",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "sales",
                "label": "Sales"
              },
              {
                "value": "support",
                "label": "Technical Support"
              },
              {
                "value": "billing",
                "label": "Billing"
              }
            ]
          },
          {
            "name": "message",
            "label": "Message",
            "type": "textarea",
            "required": true,
            "placeholder": "How can we help you?",
            "maxLength": 2000
          },
          {
            "name": "newsletterOptIn",
            "label": "Subscribe to newsletter",
            "type": "checkbox",
            "required": false,
            "defaultValue": false
          },
          {
            "name": "recaptcha",
            "type": "recaptcha",
            "required": true
          }
        ],
        "submitButton": {
          "label": "Send Message",
          "loadingLabel": "Sending...",
          "disabledUntilValid": true
        },
        "successAction": {
          "type": "message",
          "successMessage": "Thank you! We'll get back to you within 24 hours."
        },
        "rateLimiting": {
          "enabled": true,
          "maxSubmissionsPerIp": 5,
          "timeWindowSeconds": 3600
        }
      }
    },
    "video": {
      "displayName": "Video Content",
      "schema": {
        "id": "string",
        "title": "string",
        "description": "string",
        "thumbnailUrl": "string",
        "contentUrl": "string (mp4/m3u8)",
        "embedUrl": "string (iframe src)",
        "duration": "string (ISO 8601)",
        "uploadDate": "datetime",
        "channel": "string",
        "views": "number",
        "likes": "number",
        "transcript": "string (optional)",
        "captions": [
          {
            "language": "string",
            "url": "string (vtt file)"
          }
        ]
      },
      "structuredData": {
        "@type": "VideoObject",
        "name": "{{title}}",
        "description": "{{description}}",
        "thumbnailUrl": "{{thumbnailUrl}}",
        "contentUrl": "{{contentUrl}}",
        "duration": "{{duration}}",
        "uploadDate": "{{uploadDate}}"
      }
    },
    "event": {
      "displayName": "Event / Calendar Item",
      "schema": {
        "id": "string",
        "name": "string",
        "description": "string",
        "startDate": "datetime (ISO8601)",
        "endDate": "datetime",
        "timezone": "string (tz database)",
        "location": {
          "name": "string",
          "address": "string",
          "latitude": "number",
          "longitude": "number"
        },
        "virtualLink": "string (optional)",
        "organizer": {
          "name": "string",
          "email": "string",
          "url": "string"
        },
        "ticketInfo": {
          "url": "string",
          "price": "number",
          "currency": "string",
          "availability": "boolean"
        },
        "attendeeCount": "number",
        "category": "string"
      },
      "structuredData": {
        "@type": "Event",
        "name": "{{name}}",
        "startDate": "{{startDate}}",
        "endDate": "{{endDate}}",
        "location": {
          "@type": "Place",
          "name": "{{location.name}}",
          "address": "{{location.address}}"
        }
      }
    },
    "faq": {
      "displayName": "FAQ Page / Section",
      "schema": {
        "id": "string",
        "title": "string (section title)",
        "questions": [
          {
            "question": "string",
            "answer": "string (HTML/text)",
            "answerStructured": "string (optional plain text for schema)",
            "category": "string (optional)"
          }
        ]
      },
      "structuredData": {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "{{question}}",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "{{answerStructured}}"
            }
          }
        ]
      }
    },
    "directory-listing": {
      "displayName": "Directory / People / Business Listing",
      "schema": {
        "id": "string",
        "name": "string",
        "type": "person | business | organization | service",
        "description": "string",
        "image": "string (url)",
        "contactInfo": {
          "email": "string",
          "phone": "string",
          "website": "string",
          "address": {
            "street": "string",
            "city": "string",
            "state": "string",
            "postalCode": "string",
            "country": "string"
          }
        },
        "socialProfiles": [
          "string (urls)"
        ],
        "rating": {
