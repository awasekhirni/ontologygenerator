        ],
        "geo": {
          "latitude": "number",
          "longitude": "number"
        },
        "categories": [
          "string"
        ],
        "tags": [
          "string"
        ]
      },
      "structuredData": {
        "@type": "LocalBusiness",
        "name": "{{name}}",
