          "string (ids)"
        ]
      }
    },
    "user-profile": {
      "displayName": "User Profile (Deep Web)",
      "schema": {
        "userId": "string",
        "username": "string",
        "displayName": "string",
        "avatar": "string (url)",
        "bio": "string",
        "joinDate": "datetime",
        "lastActive": "datetime",
        "stats": {
          "posts": "number",
          "followers": "number",
          "following": "number"
        },
        "privacySettings": {
